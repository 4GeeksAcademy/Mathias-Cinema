{
  "name": "cinema-seat-manager",
  "version": "1.0.0",
  "description": "Sistema de reserva de asientos para cine independiente",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "serve-web": "node --loader ts-node/esm src/server.ts",
    "test": "node --loader ts-node/esm tests/pruebas.ts",
    "serve-web-prod": "node dist/server.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "type": "module",
  "keywords": [
    "cinema",
    "seat-reservation",
    "typescript"
  ],
  "author": "Mathias Cinema",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/readline-sync": "^1.4.8",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "express": "^5.2.1",
    "readline-sync": "^1.4.10"
  }
}
